# --- Runtime ---
NODE_ENV=development
PORT=3000
FRONTEND_ORIGIN=http://localhost:5173

# --- Database (Neon PostgreSQL) ---
# Pooled URL for runtime, direct URL for migrations
DATABASE_URL=postgresql://user:password@ep-xxx-pooler.region.aws.neon.tech/taskbox?sslmode=require
DIRECT_URL=postgresql://user:password@ep-xxx.region.aws.neon.tech/taskbox?sslmode=require

# --- JWT ---
# Generate with: openssl rand -base64 64
JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# --- Cloudflare R2 (S3-compatible) ---
# R2_ENDPOINT = the SIGNED write endpoint used by the backend (requires SigV4 auth per request).
R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
R2_BUCKET=taskbox-uploads
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_REGION=auto
# R2_PUBLIC_BASE_URL = the PUBLIC read URL used in <img src> tags and by the mobile app (no auth).
# Get it from the Cloudflare dashboard → R2 → your bucket → Settings → Public Access → "Allow Access".
# Looks like https://pub-xxxxxxxx.r2.dev. Swap to a custom domain (e.g. https://cdn.taskbox.pk) before launch.
R2_PUBLIC_BASE_URL=https://pub-xxxxxxxx.r2.dev

# --- Redis (Upstash or Railway) ---
REDIS_URL=redis://default:password@host:6379

# --- Email (Resend) ---
RESEND_API_KEY=
EMAIL_FROM=TaskBox <no-reply@taskbox.pk>

# --- Bootstrap admin (used only by seed script) ---
SEED_ADMIN_EMAIL=admin@taskbox.pk
SEED_ADMIN_PASSWORD=ChangeMe!2026
SEED_EXAMINER_EMAIL=examiner@taskbox.pk
SEED_EXAMINER_PASSWORD=ChangeMe!2026
